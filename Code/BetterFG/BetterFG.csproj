<Project Sdk="Microsoft.NET.Sdk">

	<!-- Build hash = SHA256 of all .cs source files in the project, truncated to 16 hex chars.
	     Deterministic: same source tree → same hash on any machine. Source change → new hash.
	     Lands in obj\...\BuildHash.g.cs as a partial of BetterFGInfo. -->
	<PropertyGroup>
	  <DisableFastUpToDateCheck>true</DisableFastUpToDateCheck>
	  <BuildHashFile>$(IntermediateOutputPath)BuildHash.g.cs</BuildHashFile>
	</PropertyGroup>
	<UsingTask TaskName="ComputeBettrFGSourceHash" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
	  <ParameterGroup>
	    <ProjectDir ParameterType="System.String" Required="true" />
	    <HashValue ParameterType="System.String" Output="true" />
	  </ParameterGroup>
	  <Task>
	    <Using Namespace="System" />
	    <Using Namespace="System.IO" />
	    <Using Namespace="System.Linq" />
	    <Using Namespace="System.Security.Cryptography" />
	    <Code Type="Fragment" Language="cs"><![CDATA[
	      var files = Directory.GetFiles(ProjectDir, "*.cs", SearchOption.AllDirectories)
	                           .Where(f => f.IndexOf("\\obj\\", StringComparison.OrdinalIgnoreCase) < 0
	                                    && f.IndexOf("\\bin\\", StringComparison.OrdinalIgnoreCase) < 0)
	                           .OrderBy(f => f, StringComparer.Ordinal)
	                           .ToArray();
	      using (var sha = SHA256.Create())
	      {
	        foreach (var f in files)
	        {
	          var rel = System.Text.Encoding.UTF8.GetBytes(f.Substring(ProjectDir.Length).Replace('\\','/') + "\n");
	          sha.TransformBlock(rel, 0, rel.Length, null, 0);
	          var bytes = File.ReadAllBytes(f);
	          sha.TransformBlock(bytes, 0, bytes.Length, null, 0);
	        }
	        sha.TransformFinalBlock(new byte[0], 0, 0);
	        HashValue = BitConverter.ToString(sha.Hash).Replace("-", "").ToLowerInvariant().Substring(0, 16);
	      }
	    ]]></Code>
	  </Task>
	</UsingTask>
	<Target Name="GenerateBuildHash" BeforeTargets="BeforeCompile;CoreCompile">
	  <ComputeBettrFGSourceHash ProjectDir="$(MSBuildProjectDirectory)\">
	    <Output TaskParameter="HashValue" PropertyName="BuildHashValue" />
	  </ComputeBettrFGSourceHash>
	  <ItemGroup>
	    <_BuildHashContent Include="namespace BetterFG.Core { public static partial class BetterFGInfo { public const string BuildHash = &quot;$(BuildHashValue)&quot;%3B } }" />
	  </ItemGroup>
	  <WriteLinesToFile File="$(BuildHashFile)" Lines="@(_BuildHashContent)" Overwrite="true" WriteOnlyWhenDifferent="false" />
	  <ItemGroup>
	    <Compile Include="$(BuildHashFile)" />
	  </ItemGroup>
	</Target>

	<!-- Fall Guys locks BetterFG.dll while running, which makes CopyDll fail with retries. Hard-kill the
	     game before we compile so the plugin file is free. Best-effort: taskkill returns non-zero if the
	     process isn't running, so ignore the exit code. -->
	<Target Name="KillFallGuysBeforeBuild" BeforeTargets="BeforeBuild" Condition="'$(SkipCopyDll)' != 'true'">
	  <Exec Command="taskkill /F /IM FallGuys_client_game.exe /T" ContinueOnError="true" />
	  <Exec Command="taskkill /F /IM FallGuys_client.exe /T" ContinueOnError="true" />
	</Target>

	<Target Name="CopyNAudio" AfterTargets="Build">
	  <Copy SourceFiles="$(NuGetPackageRoot)naudio.core\2.3.0\lib\netstandard2.0\NAudio.Core.dll" DestinationFolder="$(OutDir)" />
	  <Copy SourceFiles="$(NuGetPackageRoot)naudio.winmm\2.3.0\lib\netstandard2.0\NAudio.WinMM.dll" DestinationFolder="$(OutDir)" />
	  <Copy SourceFiles="$(NuGetPackageRoot)naudio\2.3.0\lib\net6.0\NAudio.dll" DestinationFolder="$(OutDir)" />
	</Target>

	<Target Name="PackBetterFGPayload" AfterTargets="CopyDll">
	  <Exec Command="powershell -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\..\BetterFG.Installer\repack_payload.ps1&quot; -BuildOutput &quot;$(TargetDir)&quot;" />
	</Target>

	<Target Name="PublishBetterFGInstaller" AfterTargets="PackBetterFGPayload">
	  <Exec Command="powershell -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\..\BetterFG.Installer\publish_installer.ps1&quot;" />
	</Target>

	<Target Name="PublishSkinPackager" AfterTargets="PublishBetterFGInstaller">
	  <PropertyGroup>
	    <SkinPackagerConfiguration>Release</SkinPackagerConfiguration>
	    <SkinPackagerConfiguration Condition="'$(Configuration)' == 'Debug' Or '$(Configuration)' == 'Release' Or '$(Configuration)' == 'EarlyAcesss' Or '$(Configuration)' == 'EarlyAccess_xb1'">$(Configuration)</SkinPackagerConfiguration>
	    <SkinPackagerProject>$(MSBuildProjectDirectory)\..\BetterFG.SkinPackager\BetterFG.Creator.csproj</SkinPackagerProject>
	    <SkinPackagerOutput>$(MSBuildProjectDirectory)\..\BetterFG.SkinPackager\bin\$(SkinPackagerConfiguration)\BetterFG.Creator.dll</SkinPackagerOutput>
	    <SkinPackagerGroupBat>$(MSBuildProjectDirectory)\..\BetterFG.SkinPackager\group_skins.bat</SkinPackagerGroupBat>
	    <DownloadsDir>$(USERPROFILE)\Downloads</DownloadsDir>
	  </PropertyGroup>
	  <MSBuild Projects="$(SkinPackagerProject)" Targets="Build" Properties="Configuration=$(SkinPackagerConfiguration);Platform=AnyCPU" />
	  <MakeDir Directories="$(DownloadsDir)" Condition="'$(DownloadsDir)' != '' And !Exists('$(DownloadsDir)')" />
	  <Copy SourceFiles="$(SkinPackagerOutput)" DestinationFolder="$(DownloadsDir)" OverwriteReadOnlyFiles="true" Condition="Exists('$(SkinPackagerOutput)')" />
	  <Copy SourceFiles="$(SkinPackagerGroupBat)" DestinationFolder="$(DownloadsDir)" OverwriteReadOnlyFiles="true" Condition="Exists('$(SkinPackagerGroupBat)')" />
	</Target>

  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <AssemblyName>BetterFG</AssemblyName>
    <Product>$(BettrFGDisplayName)</Product>
    <Version>$(BettrFGVersion)</Version>
    <AssemblyVersion>$(BettrFGVersion)</AssemblyVersion>
    <FileVersion>$(BettrFGVersion)</FileVersion>
    <InformationalVersion>$(BettrFGVersion)</InformationalVersion>
    <AssemblyTitle>$(BettrFGDisplayName)</AssemblyTitle>
    <BepInExPluginName>$(BettrFGDisplayName)</BepInExPluginName>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>latest</LangVersion>
    <RestoreAdditionalProjectSources>
      https://api.nuget.org/v3/index.json;
      https://nuget.bepinex.dev/v3/index.json;
      https://nuget.samboy.dev/v3/index.json
    </RestoreAdditionalProjectSources>
    <RootNamespace>BetterFG</RootNamespace>
    <Configurations>Debug;Release;Release_Profiles;XB1;EarlyAcesss;EarlyAccess_xb1</Configurations>
  </PropertyGroup>

  <!-- Profiles is a config-gated feature. Epic doesn't like it shipping in normal Release, so it's
       only compiled in when PROFILES is defined: Debug (so dev builds keep it) + Release_Profiles.
       Plain Release (and the console variants) leave it out entirely - source files are excluded
       from compilation below and every call site is wrapped in #if PROFILES. -->
  <PropertyGroup Condition="'$(Configuration)' == 'Debug' Or '$(Configuration)' == 'Release_Profiles'">
    <DefineConstants>$(DefineConstants);PROFILES</DefineConstants>
  </PropertyGroup>

  <!-- when PROFILES isn't defined, don't even compile the feature's source files -->
  <ItemGroup Condition="!$(DefineConstants.Contains('PROFILES'))">
    <Compile Remove="Customization\Profiles\ProfileService.cs" />
    <Compile Remove="Customization\Profiles\LobbyProfileService.cs" />
    <Compile Remove="UI\Windows\ProfilesWindow.cs" />
  </ItemGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'EarlyAcesss'">
    <DefineConstants>$(DefineConstants);EARLYACESSS</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'EarlyAccess_xb1'">
    <DefineConstants>$(DefineConstants);EARLYACCESS_XB1</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'XB1'">
    <DefineConstants>$(DefineConstants);XB1</DefineConstants>
  </PropertyGroup>

<Target Name="CopyDll" AfterTargets="CopyNAudio" Condition="'$(SkipCopyDll)' != 'true'">
  <MakeDir Directories="C:\Program Files (x86)\Steam\steamapps\common\Fall Guys\BepinEx\plugins\BetterFG" />
  <Copy SourceFiles="$(TargetPath)" DestinationFolder="C:\Program Files (x86)\Steam\steamapps\common\Fall Guys\BepinEx\plugins\BetterFG" OverwriteReadOnlyFiles="true" />
  <!-- launch here, as the last step of the copy, so it fires the instant the fresh plugin lands — not after
       the payload repack / installer / skinpackager chain (those are separate AfterTargets and drain later). -->
  <Exec Command="cmd /c start &quot;&quot; steam://rungameid/1097150" ContinueOnError="true" Condition="'$(SkipLaunch)' != 'true'" />
</Target>

