<Project>
  <PropertyGroup>
    <BettrFGVersion>1.2.4</BettrFGVersion>
    <BettrFGDisplayName>BettrFG</BettrFGDisplayName>
    <BettrFGInstallerName>BettrFG Installer</BettrFGInstallerName>
    <BettrFGRepoOwner>oreytv</BettrFGRepoOwner>
    <BettrFGRepoName>BettrFG</BettrFGRepoName>
    <BettrFGPayloadAssetName>BepInEx.zip</BettrFGPayloadAssetName>
    <KillAndRestartGame Condition="'$(KillAndRestartGame)' == ''">true</KillAndRestartGame>
  </PropertyGroup>
</Project>
